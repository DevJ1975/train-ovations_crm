# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT VARIABLES — Firebase App Hosting
# ─────────────────────────────────────────────────────────────────────────────
# Add ALL secrets below via:
#   Firebase Console → App Hosting → your backend → Environment Variables
# or via Secret Manager:
#   firebase apphosting:secrets:set SECRET_NAME
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Required) ───────────────────────────────────────────────────────
# Use a managed PostgreSQL provider reachable from Firebase/Cloud Run:
#   - Neon      → https://neon.tech  (recommended, serverless, free tier)
#   - Supabase  → https://supabase.com
#   - Cloud SQL → GCP console (same region as Firebase backend: us-central1)
DATABASE_URL="postgresql://user:password@host:5432/trainovations_crm?schema=public&sslmode=require"

# ── Auth (Required) ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_URL="https://YOUR_PROJECT.web.app"
AUTH_SECRET="replace-with-same-value-as-NEXTAUTH_SECRET"
AUTH_URL="https://YOUR_PROJECT.web.app"
NEXT_PUBLIC_APP_URL="https://YOUR_PROJECT.web.app"

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://YOUR_PROJECT.web.app/api/integrations/google/callback"
NEXT_PUBLIC_GOOGLE_SIGN_IN_ENABLED="true"

# ── Integrations ──────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_OAUTH_REDIRECT_URI="https://YOUR_PROJECT.web.app/api/integrations/zoom/callback"
ZOOM_WEBHOOK_SECRET=""

NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
NOTION_OAUTH_REDIRECT_URI="https://YOUR_PROJECT.web.app/api/integrations/notion/callback"
NOTION_INTERNAL_INTEGRATION_TOKEN=""

LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_OAUTH_REDIRECT_URI="https://YOUR_PROJECT.web.app/api/integrations/linkedin/callback"

ANTHROPIC_API_KEY=""

# ── Redis / Upstash (for queues and rate limiting) ────────────────────────────
# Use Upstash for serverless Redis: https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ── Receipt OCR (Mindee) ──────────────────────────────────────────────────────
MINDEE_API_KEY=""

# ── Firebase (public — safe to expose) ───────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyBF0lUQmTe5Y29abRmgr8DUFptNANGMYjI"

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
