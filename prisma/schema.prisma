  super_admin
  sales_manager
  sales_rep
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

enum SocialPlatform {
  linkedin
  x
  instagram
  facebook
  youtube
  custom
}

enum SourceType {
  landing_page
  manual
  import
  referral
}

enum ActivityLogType {
  lead_created
  lead_duplicate_detected
  lead_note_added
  lead_status_changed
  rep_profile_created
  rep_profile_updated
  landing_page_created
  meeting_processed
  meeting_note_created
  meeting_follow_up_drafted
  linkedin_profile_linked
  profile_match_confirmed
  employment_snapshot_refreshed
  employment_title_changed
  employment_company_changed
  champion_moved_companies
  champion_flag_updated
  watchlist_updated
  relationship_milestone_recorded
  relationship_edge_recorded
  career_movement_alert_created
