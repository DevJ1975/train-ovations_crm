  contactBrief       ContactBrief? @relation("ContactBriefRuns", fields: [contactBriefId], references: [id], onDelete: SetNull)
  latestForAccountBrief AccountBrief? @relation("LatestAccountBriefRun")
  latestForContactBrief ContactBrief? @relation("LatestContactBriefRun")

  @@index([leadId, briefType])
  @@index([repProfileId, generatedAt])
}

model PriorityScore {
  id                String             @id @default(cuid())
  repProfileId      String?
  leadId            String?
  entityType        PriorityEntityType
  entityKey         String
  score             Int
  band              PriorityBand
  explanation       String?
  reasonSummary     String?
  sourceConfidence  Float?
  lastEvaluatedAt   DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  repProfile        RepProfile?        @relation(fields: [repProfileId], references: [id], onDelete: SetNull)
  lead              Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  reasons           PriorityReason[]
  repTaskSuggestions RepTaskSuggestion[]

  @@unique([entityType, entityKey])
  @@index([band, lastEvaluatedAt])
  @@index([repProfileId, band])
}

model PriorityReason {
  id              String        @id @default(cuid())
  priorityScoreId String
  code            String
  label           String
  description     String?
  weight          Int           @default(0)
  sourceContext   Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  priorityScore   PriorityScore @relation(fields: [priorityScoreId], references: [id], onDelete: Cascade)

  @@index([priorityScoreId, code])
}

model RepTaskSuggestion {
  id                          String                   @id @default(cuid())
  repProfileId                String?
  leadId                      String?
  meetingId                   String?
  careerMovementAlertId       String?
  expansionOpportunitySignalId String?
  repActionPromptId           String?
  priorityScoreId             String?
  type                        RepTaskSuggestionType
  status                      RepTaskSuggestionStatus @default(generated)
  priority                    AlertPriority           @default(medium)
  title                       String
  reason                      String
  explanation                 String?
  recommendedDueAt            DateTime?
  scheduledAt                 DateTime?
  scheduledEndAt              DateTime?
  snoozedUntil                DateTime?
  confidenceScore             Float?
  sourceContext               Json?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  repProfile                  RepProfile?              @relation(fields: [repProfileId], references: [id], onDelete: SetNull)
  lead                        Lead?                    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  meeting                     Meeting?                 @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  careerMovementAlert         CareerMovementAlert?     @relation(fields: [careerMovementAlertId], references: [id], onDelete: SetNull)
  expansionOpportunitySignal  ExpansionOpportunitySignal? @relation(fields: [expansionOpportunitySignalId], references: [id], onDelete: SetNull)
  repActionPrompt             RepActionPrompt?         @relation(fields: [repActionPromptId], references: [id], onDelete: SetNull)
  priorityScore               PriorityScore?           @relation(fields: [priorityScoreId], references: [id], onDelete: SetNull)

  @@index([repProfileId, status])
  @@index([leadId, priority])
}

model NotionSyncRecord {
  id                 String            @id @default(cuid())
  userId             String
  connectedAccountId String?
  meetingId          String?
  callSummaryId      String?
  emailDraftId       String?
  destinationType    NoteDestinationType
  sourceEntityType   String
  sourceEntityId     String
  notionPageId       String?
  notionDatabaseId   String?
  syncStatus         SyncStatus        @default(idle)
  externalUrl        String?
  lastSyncedAt       DateTime?
  errorMessage       String?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount   ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  meeting            Meeting?          @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  callSummary        CallSummary?      @relation(fields: [callSummaryId], references: [id], onDelete: SetNull)
  emailDraft         EmailDraft?       @relation(fields: [emailDraftId], references: [id], onDelete: SetNull)
}

model WebhookEvent {
  id                 String             @id @default(cuid())
  provider           ConnectedProvider
  eventType          String
  deliveryId         String?
  status             WebhookEventStatus @default(received)
  verified           Boolean            @default(false)
  headers            Json?
  payload            Json
  errorMessage       String?
  receivedAt         DateTime           @default(now())
  processedAt        DateTime?
  connectedAccountId String?
  meetingId          String?
  connectedAccount   ConnectedAccount?  @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  meeting            Meeting?           @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  @@unique([provider, deliveryId])
}

model RepJournalEntry {
  id           String     @id @default(cuid())
  repProfileId String
  title        String?
  body         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  repProfile   RepProfile @relation(fields: [repProfileId], references: [id], onDelete: Cascade)

  @@index([repProfileId, createdAt])
}

model RepNote {
  id             String           @id @default(cuid())
  repProfileId   String
  title          String?
  body           String
  templateType   NoteTemplateType @default(blank)
  leadId         String?
  accountId      String?
  opportunityId  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  repProfile     RepProfile       @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
  lead           Lead?            @relation("LeadRepNotes", fields: [leadId], references: [id], onDelete: SetNull)
  account        Account?         @relation("AccountRepNotes", fields: [accountId], references: [id], onDelete: SetNull)
  opportunity    Opportunity?     @relation("OpportunityRepNotes", fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([repProfileId, createdAt])
  @@index([leadId])
  @@index([accountId])
  @@index([opportunityId])
}

model Proposal {
  id                    String              @id @default(cuid())
  repProfileId          String
  leadId                String?
  accountId             String?
  opportunityId         String?
  templateId            String?
  title                 String
  status                ProposalStatus      @default(draft)
  // Legacy flat-text fields kept for backward compat / AI generation
  executiveSummary      String?
  aboutUs               String?
  scopeOfWork           String?
  deliverables          String?
  timeline              String?
  pricing               String?
  terms                 String?
  nextSteps             String?
  // Block engine
  useBlockEngine        Boolean             @default(false)
  // Client identity
  clientName            String?
  clientEmail           String?
  clientCompany         String?
  // Branding
  coverImageUrl         String?
  brandColor            String?
  fontFamily            String?
  footerText            String?
  // Financials
  totalValueCents       Int?
  paymentType           ProposalPaymentType @default(none)
  depositPercent        Int?
  // Scheduling
  schedulingUrl         String?
  // Stripe
  stripeSessionId       String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  partiallyPaidAt       DateTime?
  // Lifecycle
  expiresAt             DateTime?
  sentAt                DateTime?
  viewedAt              DateTime?
  acceptedAt            DateTime?
  declinedAt            DateTime?
  shareToken            String?             @unique
  // AI
  aiGeneratedAt         DateTime?
  // Signature
  signatureData         String?
  signerName            String?
  signerEmail           String?
  signerTitle           String?
  signedAt              DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  repProfile            RepProfile          @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
  lead                  Lead?               @relation("LeadProposals", fields: [leadId], references: [id], onDelete: SetNull)
  account               Account?            @relation("AccountProposals", fields: [accountId], references: [id], onDelete: SetNull)
  opportunity           Opportunity?        @relation("OpportunityProposals", fields: [opportunityId], references: [id], onDelete: SetNull)
  blocks                ProposalBlock[]
  packages              ProposalPricingPackage[]
  analyticsEvents       ProposalAnalyticsEvent[]
  payments              ProposalPayment[]

  @@index([repProfileId, status])
  @@index([shareToken])
  @@index([leadId])
  @@index([accountId])
  @@index([opportunityId])
}

model ProposalBlock {
  id         String            @id @default(cuid())
  proposalId String
  blockType  ProposalBlockType
  position   Int
  isVisible  Boolean           @default(true)
  content    Json
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  proposal   Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, position])
}

model ProposalPricingPackage {
  id              String                @id @default(cuid())
  proposalId      String
  name            String
  description     String?
  priceCents      Int
  isRecurring     Boolean               @default(false)
  recurringPeriod String?
  isFeatured      Boolean               @default(false)
  position        Int                   @default(0)
  features        String[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  proposal        Proposal              @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  addOns          ProposalPackageAddOn[]

  @@index([proposalId])
}

model ProposalPackageAddOn {
  id          String                 @id @default(cuid())
  packageId   String
  name        String
  description String?
  priceCents  Int
  isOptional  Boolean                @default(true)
  position    Int                    @default(0)
  createdAt   DateTime               @default(now())
  package     ProposalPricingPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

model ProposalTemplate {
  id          String                  @id @default(cuid())
  repProfileId String?
  name        String
  description String?
  category    String?
  isGlobal    Boolean                 @default(false)
  previewUrl  String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  blocks      ProposalTemplateBlock[]

  @@index([repProfileId])
  @@index([isGlobal])
}

model ProposalTemplateBlock {
  id          String            @id @default(cuid())
  templateId  String
  blockType   ProposalBlockType
  position    Int
  content     Json
  createdAt   DateTime          @default(now())
  template    ProposalTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, position])
}

model ProposalAnalyticsEvent {
  id           String            @id @default(cuid())
  proposalId   String
  eventType    ProposalEventType
  sessionId    String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  occurredAt   DateTime          @default(now())
  proposal     Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, eventType])
  @@index([proposalId, occurredAt])
}

model ProposalPayment {
  id                    String   @id @default(cuid())
  proposalId            String
  stripePaymentIntentId String?  @unique
  stripeSessionId       String?  @unique
  amountCents           Int
  currency              String   @default("usd")
  status                String
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  proposal              Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model RepQuota {
  id             String   @id @default(cuid())
  repProfileId   String
  period         String
  targetCents    Int
  closedCents    Int      @default(0)
  pipelineCents  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  repProfile     RepProfile @relation(fields: [repProfileId], references: [id], onDelete: Cascade)

  @@unique([repProfileId, period])
  @@index([repProfileId])
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  userId      String
  url         String
  secret      String
  events      String[]
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FollowUpSequence {
  id           String               @id @default(cuid())
  repProfileId String
  name         String
  description  String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  repProfile   RepProfile           @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
  steps        FollowUpStep[]
  enrollments  FollowUpEnrollment[]

  @@index([repProfileId])
}

model FollowUpStep {
  id           String           @id @default(cuid())
  sequenceId   String
  stepNumber   Int
  delayDays    Int
  subject      String?
  bodyTemplate String
  createdAt    DateTime         @default(now())
  sequence     FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
}

model FollowUpEnrollment {
  id           String              @id @default(cuid())
  sequenceId   String
  leadId       String
  currentStep  Int                 @default(0)
  status       EnrollmentStatus    @default(active)
  startedAt    DateTime            @default(now())
  completedAt  DateTime?
  cancelledAt  DateTime?
  nextSendAt   DateTime?
  sequence     FollowUpSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead         Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([sequenceId])
  @@index([leadId])
  @@index([nextSendAt])
}

enum EnrollmentStatus {
  active
  paused
  completed
  cancelled
}

model Booking {
  id            String     @id @default(cuid())
  repProfileId  String
  guestName     String
  guestEmail    String
  guestPhone    String?
  guestNotes    String?
  requestedAt   DateTime
  durationMins  Int        @default(30)
  status        String     @default("pending")
  createdAt     DateTime   @default(now())
  repProfile    RepProfile @relation(fields: [repProfileId], references: [id], onDelete: Cascade)

  @@index([repProfileId])
}
