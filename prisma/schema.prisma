enum RepTaskSuggestionType {
  send_follow_up
  reconnect_contact
  review_account_brief
  update_champion_status
  schedule_check_in
  send_proposal_reminder
  revive_opportunity
  verify_company_change
}

enum RepTaskSuggestionStatus {
  generated
  acknowledged
  dismissed
  converted
  archived
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String?
  imageUrl        String?
  role            UserRole
  isActive        Boolean       @default(true)
  mustChangePassword Boolean    @default(false)
  invitedByUserId String?
  invitationSentAt DateTime?
  invitationAcceptedAt DateTime?
  lastLoginAt     DateTime?
  deactivatedAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  repProfile      RepProfile?
  authoredNotes   LeadNote[]
  activityEntries ActivityLog[] @relation("ActivityActor")
  connectedAccounts ConnectedAccount[]
  managedRepProfiles RepProfile[] @relation("RepManager")
  invitedBy       User?         @relation("RepInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  invitedUsers    User[]        @relation("RepInviter")
  calendarEvents  CalendarEvent[]
  meetings        Meeting[]
  automationJobs  AutomationJob[]
  notionSyncRecords NotionSyncRecord[]
  emailDrafts     EmailDraft[]
  emailMailboxes  EmailMailbox[]
  generatedOutreachDrafts OutreachDraft[]      @relation("OutreachDraftGenerator")
  editedOutreachDrafts    OutreachDraft[]      @relation("OutreachDraftEditor")
  briefGenerationRuns     BriefGenerationRun[] @relation("BriefRunActor")
  webhookEndpoints        WebhookEndpoint[]

  @@index([invitedByUserId])
}

model OrganizationSettings {
  id                String     @id @default(cuid())
  name              String
  website           String?
  supportEmail      String?
  supportPhone      String?
  defaultLeadSource SourceType @default(landing_page)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model RepProfile {
  id               String               @id @default(cuid())
  userId           String               @unique
  managerUserId    String?
  slug             String               @unique
  firstName        String
  lastName         String
  displayName      String
  title            String
  bio              String
  photoUrl         String?
  pushToken        String?
  email            String
  phone            String?
  website          String?
  location         String?
  isActive              Boolean   @default(true)
  onboardingComplete    Boolean   @default(false)
  bookingEnabled        Boolean   @default(false)
  bookingTitle          String?
  bookingDuration       Int       @default(30)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  managerUser      User?                @relation("RepManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  signatureProfile RepSignatureProfile?
  socialLinks      RepSocialLink[]
  landingPages     LandingPage[]
  ownedLeads       Lead[]               @relation("LeadOwner")
  activityEntries  ActivityLog[]        @relation("RepActivity")
  meetings         Meeting[]
  emailDrafts      EmailDraft[]
  relationshipHistory RelationshipHistory[]
  championFlagsOwned ChampionFlag[]     @relation("ChampionOwner")
  relationshipMilestones RelationshipMilestone[]
  expansionOpportunitySignals ExpansionOpportunitySignal[]
  repActionPrompts RepActionPrompt[]
  relationshipEdges RelationshipEdge[]
  outreachDrafts    OutreachDraft[]
  accountBriefs     AccountBrief[]
  contactBriefs     ContactBrief[]
  priorityScores    PriorityScore[]
  repTaskSuggestions RepTaskSuggestion[]
  briefGenerationRuns BriefGenerationRun[]
  draftGenerationContexts DraftGenerationContext[]
  ownedAccounts      Account[]             @relation("AccountOwner")
  ownedOpportunities Opportunity[]         @relation("OpportunityOwner")
  emailThreads       EmailThread[]
  journalEntries     RepJournalEntry[]
  repNotes           RepNote[]
  proposals          Proposal[]
  expenses           Expense[]
  quotas             RepQuota[]
  followUpSequences  FollowUpSequence[]
  bookings           Booking[]

  @@index([managerUserId])
}

model RepSignatureProfile {
  id             String     @id @default(cuid())
  repProfileId   String     @unique
  companyName    String
  jobTitle       String?
  primaryPhone   String?
  secondaryPhone String?
  email          String?
  website        String?
  linkedinUrl    String?
  calendarUrl    String?
  address        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  repProfile     RepProfile @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
}

model RepSocialLink {
  id           String         @id @default(cuid())
  repProfileId String
  platform     SocialPlatform
  label        String
  url          String
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  repProfile   RepProfile     @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
}

enum ExpenseCategory {
  meals
  travel
  lodging
  entertainment
  supplies
  software
  marketing
  other
}

model Expense {
  id           String          @id @default(cuid())
  repProfileId String
  amount       Float
  currency     String          @default("USD")
  vendor       String?
  category     ExpenseCategory @default(other)
  date         DateTime        @default(now())
  notes        String?
  receiptUrl   String?
  ocrRaw       Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  repProfile   RepProfile      @relation(fields: [repProfileId], references: [id], onDelete: Cascade)

  @@index([repProfileId])
}

model LandingPage {
  id              String     @id @default(cuid())
  repProfileId    String
  slug            String     @unique
  title           String
  headline        String
  subheadline     String?
  heroCtaText     String     @default("Save Contact")
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  repProfile      RepProfile @relation(fields: [repProfileId], references: [id], onDelete: Cascade)
  leads           Lead[]
}

model Lead {
  id                String        @id @default(cuid())
  repProfileId      String?
  landingPageId     String?
  firstName         String
  lastName          String
  company           String?
  jobTitle          String?
  email             String
  phone             String?
  location          String?
  industry          String?
  interest          String?
  notes             String?
  consent           Boolean
  status            LeadStatus    @default(new)
  sourceType        SourceType    @default(landing_page)
  queryParams       Json?
  duplicateOfLeadId String?
  submittedAt       DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  repProfile        RepProfile?   @relation("LeadOwner", fields: [repProfileId], references: [id], onDelete: SetNull)
  landingPage       LandingPage?  @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  duplicateOfLead   Lead?         @relation("LeadDuplicates", fields: [duplicateOfLeadId], references: [id], onDelete: SetNull)
  duplicateLeads    Lead[]        @relation("LeadDuplicates")
  notesList         LeadNote[]
  activityEntries   ActivityLog[] @relation("LeadActivity")
  meetings          Meeting[]
  emailDrafts       EmailDraft[]
  actionItems       ActionItem[]
  linkedInProfileLinks LinkedInProfileLink[]
  employmentSnapshots EmploymentSnapshot[]
  employmentChangeEvents EmploymentChangeEvent[]
  profileMatchCandidates ProfileMatchCandidate[]
  relationshipHistory RelationshipHistory[]
  championFlag       ChampionFlag?
  contactWatchlist   ContactWatchlist?
  careerMovementAlerts CareerMovementAlert[]
  relationshipMilestones RelationshipMilestone[]
  contactCompanyAssociations ContactCompanyAssociation[]
  expansionOpportunitySignals ExpansionOpportunitySignal[]
  repActionPrompts RepActionPrompt[]
  relationshipEdges RelationshipEdge[]
  outreachDrafts       OutreachDraft[]
  accountBriefs        AccountBrief[]
  contactBriefs        ContactBrief[]
  priorityScores       PriorityScore[]
  repTaskSuggestions   RepTaskSuggestion[]
  draftGenerationContexts DraftGenerationContext[]
  briefGenerationRuns  BriefGenerationRun[]
  accountLinks         AccountContact[]
  primaryOpportunities Opportunity[]       @relation("OpportunityPrimaryLead")
  emailThreads         EmailThread[]
  repNotes             RepNote[]           @relation("LeadRepNotes")
  proposals            Proposal[]          @relation("LeadProposals")
  followUpEnrollments  FollowUpEnrollment[]

  @@index([email])
  @@index([phone])
  @@index([repProfileId, status])
}

model Account {
  id               String        @id @default(cuid())
  name             String
  domain           String?
  industry         String?
  status           AccountStatus @default(prospect)
  ownerRepProfileId String?
  description      String?
  hqLocation       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ownerRepProfile  RepProfile?   @relation("AccountOwner", fields: [ownerRepProfileId], references: [id], onDelete: SetNull)
  contacts         AccountContact[]
  opportunities    Opportunity[]
  emailThreads     EmailThread[]
  repNotes         RepNote[]        @relation("AccountRepNotes")
  proposals        Proposal[]       @relation("AccountProposals")

  @@index([ownerRepProfileId, status])
  @@index([name])
  @@index([domain])
}

model AccountContact {
  id                String    @id @default(cuid())
  accountId         String
  leadId            String
  relationshipLabel String?
  isPrimary         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([accountId, leadId])
  @@index([leadId])
}

model Opportunity {
  id               String           @id @default(cuid())
  accountId        String
  ownerRepProfileId String?
  primaryLeadId    String?
  name             String
  stage            OpportunityStage @default(prospecting)
  amountCents      Int?
  currency         String           @default("USD")
  targetCloseDate  DateTime?
  closeDate        DateTime?
  description      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ownerRepProfile  RepProfile?      @relation("OpportunityOwner", fields: [ownerRepProfileId], references: [id], onDelete: SetNull)
  primaryLead      Lead?            @relation("OpportunityPrimaryLead", fields: [primaryLeadId], references: [id], onDelete: SetNull)
  emailThreads     EmailThread[]
  repNotes         RepNote[]        @relation("OpportunityRepNotes")
  proposals        Proposal[]       @relation("OpportunityProposals")

  @@index([accountId, stage])
  @@index([ownerRepProfileId, stage])
  @@index([primaryLeadId])
}

model EmailMailbox {
  id                 String                  @id @default(cuid())
  userId             String
  connectedAccountId String?
  provider           MailboxProvider
  connectionStatus   MailboxConnectionStatus @default(pending)
  label              String
  emailAddress       String
  syncEnabled        Boolean                 @default(true)
  lastSyncedAt       DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount   ConnectedAccount?       @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  threads            EmailThread[]

  @@unique([userId, emailAddress])
  @@index([userId, connectionStatus])
}

model EmailThread {
  id               String            @id @default(cuid())
  mailboxId        String
  repProfileId     String?
  leadId           String?
  accountId        String?
  opportunityId    String?
  providerThreadId String?
  subject          String
  snippet          String?
  participants     Json?
  unreadCount      Int               @default(0)
  status           EmailThreadStatus @default(open)
  awaitingReply    Boolean           @default(false)
  followUpNeeded   Boolean           @default(false)
  snoozedUntil     DateTime?
  lastMessageAt    DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  mailbox          EmailMailbox      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  repProfile       RepProfile?       @relation(fields: [repProfileId], references: [id], onDelete: SetNull)
  lead             Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account          Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunity      Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  messages         EmailMessage[]

  @@index([mailboxId, lastMessageAt])
  @@index([repProfileId, lastMessageAt])
  @@index([leadId, lastMessageAt])
  @@index([accountId, lastMessageAt])
}

model EmailMessage {
  id                String                @id @default(cuid())
  threadId          String
  providerMessageId String?
  direction         EmailMessageDirection
  subject           String?
  snippet           String?
  bodyText          String
  fromEmail         String
  toEmails          String[]
  ccEmails          String[]              @default([])
  isRead            Boolean               @default(false)
  sentAt            DateTime
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  thread            EmailThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt])
}

model LeadNote {
  id            String             @id @default(cuid())
  leadId        String
  authorId      String?
  meetingId     String?
  callSummaryId String?
  sourceType    LeadNoteSourceType @default(user_authored)
  content       String
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lead          Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author        User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  meeting       Meeting?           @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  callSummary   CallSummary?       @relation(fields: [callSummaryId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id           String          @id @default(cuid())
  type         ActivityLogType
  description  String
  actorUserId  String?
  repProfileId String?
  leadId       String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  actorUser    User?           @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  repProfile   RepProfile?     @relation("RepActivity", fields: [repProfileId], references: [id], onDelete: SetNull)
  lead         Lead?           @relation("LeadActivity", fields: [leadId], references: [id], onDelete: SetNull)
}

model ExternalProfileSource {
  id              String                  @id @default(cuid())
  provider        ExternalProfileProvider
  sourceType      ProfileSourceType
  label           String
  description     String?
  isOfficial      Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  linkedInProfileLinks LinkedInProfileLink[]
  employmentSnapshots EmploymentSnapshot[]
  profileMatchCandidates ProfileMatchCandidate[]
  employmentChangeEvents EmploymentChangeEvent[]
  relationshipHistory RelationshipHistory[]
  careerMovementAlerts CareerMovementAlert[]
  relationshipMilestones RelationshipMilestone[]
  contactCompanyAssociations ContactCompanyAssociation[]
}

model LinkedInProfileLink {
  id                    String                  @id @default(cuid())
  leadId                String
  externalProfileSourceId String?
  profileUrl            String
  normalizedProfileUrl  String
  memberId              String?
  publicIdentifier      String?
  headline              String?
  location              String?
  sourceType            ProfileSourceType
  status                LinkedInProfileLinkStatus @default(active)
  confidenceScore       Float                   @default(0.5)
  humanConfirmed        Boolean                 @default(false)
  officialData          Boolean                 @default(false)
  lastCheckedAt         DateTime?
  lastConfirmedAt       DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  lead                  Lead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  externalProfileSource ExternalProfileSource?  @relation(fields: [externalProfileSourceId], references: [id], onDelete: SetNull)
  employmentSnapshots   EmploymentSnapshot[]
  employmentChangeEvents EmploymentChangeEvent[]
  careerMovementAlerts  CareerMovementAlert[]
  relationshipHistory   RelationshipHistory[]

  @@unique([leadId, normalizedProfileUrl])
  @@index([normalizedProfileUrl])
}

model EmploymentSnapshot {
  id                    String                 @id @default(cuid())
  leadId                String
  linkedInProfileLinkId String?
  externalProfileSourceId String?
  title                 String
  companyName           String
  startDate             DateTime?
  endDate               DateTime?
  isCurrent             Boolean                @default(true)
  companyPageUrl        String?
  profileUrl            String?
  sourceType            ProfileSourceType
  confidenceScore       Float                  @default(0.5)
  retrievedAt           DateTime
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  metadata              Json?
  lead                  Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  linkedInProfileLink   LinkedInProfileLink?   @relation(fields: [linkedInProfileLinkId], references: [id], onDelete: SetNull)
  externalProfileSource ExternalProfileSource? @relation(fields: [externalProfileSourceId], references: [id], onDelete: SetNull)
  priorChangeEvents     EmploymentChangeEvent[] @relation("PriorEmploymentSnapshot")
  currentChangeEvents   EmploymentChangeEvent[] @relation("CurrentEmploymentSnapshot")

  @@index([leadId, retrievedAt])
}

model EmploymentChangeEvent {
  id                    String                 @id @default(cuid())
  leadId                String
  linkedInProfileLinkId String?
  externalProfileSourceId String?
  priorSnapshotId       String?
  currentSnapshotId     String?
  changeType            EmploymentChangeType
  titleFrom             String?
  titleTo               String?
  companyFrom           String?
  companyTo             String?
  confidenceScore       Float                  @default(0.5)
  detectedAt            DateTime               @default(now())
  metadata              Json?
  lead                  Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
